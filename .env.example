# ============================================================
# Arbiter – Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Set to true to enable FastAPI debug mode (do NOT use in production)
DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Redis ───────────────────────────────────────────────────
# Redis connection URL used by the gateway for caching and rate-limit counters.
# When running via docker-compose the service name "redis" resolves automatically.
REDIS_URL=redis://redis:6379

# How long (seconds) to cache LLM responses for deterministic requests (temp ≤ 0.3)
CACHE_TTL=3600

# ── Gateway Auth ────────────────────────────────────────────
# Optional: require callers to pass  Authorization: Bearer <key>.
#
# GATEWAY_API_KEYS (preferred)  — comma-separated list of valid Bearer tokens.
# GATEWAY_API_KEY  (legacy)     — single token; still respected for backward compat.
#
# Leave both empty to disable gateway-level authentication entirely.
GATEWAY_API_KEYS=
GATEWAY_API_KEY=

# ── Provider API Keys ────────────────────────────────────────
# Supply one or more keys per provider separated by commas.
# Keys are round-robin rotated with Redis-backed rate-limit tracking.

# Google Gemini  (https://aistudio.google.com/app/apikey)
# Add one key per account, comma-separated.  The router scores all keys by
# remaining quota (daily > RPM > TPM) and picks the best one automatically.
# Example: 3 Gemini accounts → 3 keys
GEMINI_API_KEYS=your-gemini-account1-key,your-gemini-account2-key,your-gemini-account3-key

# Groq  (https://console.groq.com/keys)
# Example: 2 Groq accounts
GROQ_API_KEYS=your-groq-account1-key,your-groq-account2-key

# OpenRouter  (https://openrouter.ai/keys)
OPENROUTER_API_KEYS=your-openrouter-key-1

# Cohere  (https://dashboard.cohere.com/api-keys)
COHERE_API_KEYS=your-cohere-key-1

# ── New Providers ─────────────────────────────────────────────

# Cloudflare Workers AI  (https://dash.cloudflare.com/ → Workers AI)
# Format: account_id|api_token  (the pipe character separates them)
# Multiple accounts: account1_id|token1,account2_id|token2
# Free tier: 300 RPM, ~10K neurons/day
# Get your Account ID from https://dash.cloudflare.com/
# Create an API token with "Workers AI (Read)" scope
CLOUDFLARE_API_KEYS=your-account-id|your-api-token
# Optional: Dedicated account-ID field (used by the Cloudflare manager API
# when CLOUDFLARE_API_KEYS is empty)
CLOUDFLARE_ACCOUNT_ID=

# Cerebras Inference  (https://cloud.cerebras.ai/platform → API Keys)
# Free tier: 30 RPM · 60K TPM · 1M tokens/day per key
# Multiple keys: key1,key2
CEREBRAS_API_KEYS=your-cerebras-api-key

# HuggingFace Inference API  (https://huggingface.co/settings/tokens)
# Create a token with "Read" or "Write" scope.
# Free tier: limited monthly inference credits (~$0.10/month equivalent)
HUGGINGFACE_API_KEYS=hf_your-token-here

# Modal.com — serverless GPU (https://modal.com)
# Used for the one-click vLLM deploy feature in Settings → Modal GPU tab.
# Run `modal token new` in your terminal to generate these, or visit modal.com → Settings → API Tokens.
# $30 free credits/month; you only pay while a container is running.
MODAL_TOKEN_ID=ak-your-token-id
MODAL_TOKEN_SECRET=as-your-token-secret

# Z.ai / Zhipu AI  (https://z.ai/manage-apikey)
# Free tier: GLM-4.7-Flash, GLM-4.5-Flash, GLM-Z1-Flash are $0 (completely free)
# ~10 RPM conservative estimate; no published daily limit
ZAI_API_KEYS=your-zai-api-key

# Lightning.ai LitAI  (https://lightning.ai → Settings → API Keys)
# OpenAI-compatible API with natively hosted open-weight models
# Free tier: ~37 million token welcome credit on signup, then pay-per-use ($0.09-$0.52/M tokens)
# Models: gpt-oss-120B, gpt-oss-20B, Nemotron 3 Super (256K ctx), DeepSeek V3.1 (164K ctx), Llama 3.3 70B
# Docs: https://lightning.ai/docs/litai/home
LIGHTNING_API_KEYS=your-lightning-api-key

# Pollinations.ai — completely free, no key required.
# The gateway automatically uses a dummy "free" key for this provider.
# You do NOT need to set anything here; Pollinations works out of the box.
# POLLINATIONS_API_KEYS=  ← intentionally omitted

# ── Cloudflare Zero Trust / Access (optional) ─────────────────
# Enable Cloudflare Access JWT validation on all protected endpoints.
# When enabled, every request must carry a valid  Cf-Access-Jwt-Assertion  header
# issued by your Cloudflare Access application.
#
# ENABLE_CF_ACCESS           Set to true to activate the middleware.
# CLOUDFLARE_ACCESS_TEAM_NAME  Your Cloudflare Access team name
#                              (e.g. "myteam" → https://myteam.cloudflareaccess.com)
# CLOUDFLARE_ACCESS_AUD      Application Audience (AUD) tag from the Access app settings.
#                              Leave empty to skip audience verification.
ENABLE_CF_ACCESS=false
CLOUDFLARE_ACCESS_TEAM_NAME=
CLOUDFLARE_ACCESS_AUD=
