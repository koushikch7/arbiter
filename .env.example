# ============================================================
# Arbiter – Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Set to true to enable FastAPI debug mode (do NOT use in production)
DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Redis ───────────────────────────────────────────────────
# Redis connection URL used by the gateway for caching and rate-limit counters.
# When running via docker-compose the service name "redis" resolves automatically.
REDIS_URL=redis://redis:6379

# How long (seconds) to cache LLM responses for deterministic requests (temp ≤ 0.3)
CACHE_TTL=3600

# ── Gateway Auth ────────────────────────────────────────────
# Optional: require callers to pass  Authorization: Bearer <key>.
#
# GATEWAY_API_KEYS (preferred)  — comma-separated list of valid Bearer tokens.
# GATEWAY_API_KEY  (legacy)     — single token; still respected for backward compat.
#
# Leave both empty to disable gateway-level authentication entirely.
GATEWAY_API_KEYS=
GATEWAY_API_KEY=

# ── Provider API Keys ────────────────────────────────────────
# Supply one or more keys per provider separated by commas.
# Keys are round-robin rotated with Redis-backed rate-limit tracking.

# Google Gemini  (https://aistudio.google.com/app/apikey)
# Add one key per account, comma-separated.  The router scores all keys by
# remaining quota (daily > RPM > TPM) and picks the best one automatically.
#
# PER-KEY TIER TAGGING (v1.13.3+):
#   Tag a key with `#paid` to allow it for paid-only models like
#   gemini-3.1-pro-preview, gemini-3-pro-preview, gemini-2.5-pro.
#   Untagged keys default to `#free` — they will only serve free-tier models
#   and will be skipped (gracefully) for paid model requests.
#
# Example layouts:
#   1 paid + 2 free :  KEY1#paid,KEY2,KEY3
#   3 free only     :  KEY1,KEY2,KEY3
#   2 paid          :  KEY1#paid,KEY2#paid
GEMINI_API_KEYS=your-gemini-account1-key,your-gemini-account2-key,your-gemini-account3-key

# Groq  (https://console.groq.com/keys)
# Example: 2 Groq accounts
GROQ_API_KEYS=your-groq-account1-key,your-groq-account2-key

# OpenRouter  (https://openrouter.ai/keys)
OPENROUTER_API_KEYS=your-openrouter-key-1

# Cohere  (https://dashboard.cohere.com/api-keys)
COHERE_API_KEYS=your-cohere-key-1

# ── New Providers ─────────────────────────────────────────────

# Cloudflare Workers AI  (https://dash.cloudflare.com/ → Workers AI)
# Format: account_id|api_token  (the pipe character separates them)
# Multiple accounts: account1_id|token1,account2_id|token2
# Free tier: 300 RPM, ~10K neurons/day
# Get your Account ID from https://dash.cloudflare.com/
# Create an API token with "Workers AI (Read)" scope
CLOUDFLARE_API_KEYS=your-account-id|your-api-token
# Optional: Dedicated account-ID field (used by the Cloudflare manager API
# when CLOUDFLARE_API_KEYS is empty)
CLOUDFLARE_ACCOUNT_ID=

# Cerebras Inference  (https://cloud.cerebras.ai/platform → API Keys)
# Free tier: 30 RPM · 60K TPM · 1M tokens/day per key
# Multiple keys: key1,key2
CEREBRAS_API_KEYS=your-cerebras-api-key

# HuggingFace Inference API  (https://huggingface.co/settings/tokens)
# Create a token with "Read" or "Write" scope.
# Free tier: limited monthly inference credits (~$0.10/month equivalent)
HUGGINGFACE_API_KEYS=hf_your-token-here

# Modal.com — serverless GPU (https://modal.com)
# Used for the one-click vLLM deploy feature in Settings → Modal GPU tab.
# Run `modal token new` in your terminal to generate these, or visit modal.com → Settings → API Tokens.
# $30 free credits/month; you only pay while a container is running.
MODAL_TOKEN_ID=ak-your-token-id
MODAL_TOKEN_SECRET=as-your-token-secret

# Z.ai / Zhipu AI  (https://z.ai/manage-apikey)
# Free tier: GLM-4.7-Flash, GLM-4.5-Flash, GLM-Z1-Flash are $0 (completely free)
# ~10 RPM conservative estimate; no published daily limit
ZAI_API_KEYS=your-zai-api-key

# Lightning.ai LitAI  (https://lightning.ai → Settings → API Keys)
# OpenAI-compatible API with natively hosted open-weight models
# Free tier: ~37 million token welcome credit on signup, then pay-per-use ($0.09-$0.52/M tokens)
# Models: gpt-oss-120B, gpt-oss-20B, Nemotron 3 Super (256K ctx), DeepSeek V3.1 (164K ctx), Llama 3.3 70B
# Docs: https://lightning.ai/docs/litai/home
LIGHTNING_API_KEYS=your-lightning-api-key

# Pollinations.ai — free tier available, API key now required.
# Get your key at: https://enter.pollinations.ai/ (keys start with sk_ or pk_)
POLLINATIONS_API_KEYS=your-pollinations-sk_key

# ── Google OAuth2 Login (optional) ────────────────────────────
# When set, the web UI (dashboard, analytics, settings, etc.) requires
# users to sign in with their Google account before accessing any page.
#
# Setup:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID (Web application type)
#   3. Add Authorized redirect URI: http://localhost:8000/auth/callback
#      (or your production URL)
#   4. Copy Client ID and Client Secret below.
#
# Leave GOOGLE_CLIENT_ID empty to disable Google login entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Optional: restrict access to specific email addresses or domains.
# Leave both empty to allow any Google account to sign in.
# GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com
# GOOGLE_ALLOWED_DOMAINS=mycompany.com
GOOGLE_ALLOWED_EMAILS=
GOOGLE_ALLOWED_DOMAINS=

# Secret used to sign session tokens — set to a random string in production.
# If empty, a random secret is generated on startup (sessions invalidated on restart).
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Routeway  (https://docs.routeway.ai/getting-started/introduction)
# OpenAI-compatible gateway; free tier + paid tiers
ROUTEWAY_API_KEYS=your-routeway-key-1

# ── Google SSO (optional, for the admin dashboard) ───────────
# When these are set, all non-/v1/* UI pages require a Google sign-in and
# an admin approval. The /v1/* API still uses GATEWAY_API_KEYS Bearer tokens.
#
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#   Authorised redirect URI:  <APP_BASE_URL>/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email of the bootstrap administrator. First sign-in from this address is
# auto-approved and given admin rights. They can then approve other users.
ADMIN_EMAIL=

# Public base URL of this Arbiter deployment (used to build the OAuth callback).
# Example: https://arbiter.example.com
APP_BASE_URL=http://localhost:8000

# Random long string (>= 32 chars). Sessions are signed with this key.
# REQUIRED whenever Google SSO is enabled.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=

# Set to "true" in production (HTTPS); cookies then carry the Secure flag.
SESSION_COOKIE_SECURE=false

# Max session lifetime in seconds (default: 86400 = 24h)
SESSION_MAX_AGE=86400

# Comma-separated list of origins allowed to call the API with credentials.
# Wildcard "*" is REJECTED at startup when Google SSO is on. Leave empty
# to default to APP_BASE_URL only.
ALLOWED_CORS_ORIGINS=

# ── Cloudflare Zero Trust / Access (optional) ─────────────────
# Enable Cloudflare Access JWT validation on all protected endpoints.
# When enabled, every request must carry a valid  Cf-Access-Jwt-Assertion  header
# issued by your Cloudflare Access application.
#
# ENABLE_CF_ACCESS           Set to true to activate the middleware.
# CLOUDFLARE_ACCESS_TEAM_NAME  Your Cloudflare Access team name
#                              (e.g. "myteam" → https://myteam.cloudflareaccess.com)
# CLOUDFLARE_ACCESS_AUD      Application Audience (AUD) tag from the Access app settings.
#                              Leave empty to skip audience verification.
ENABLE_CF_ACCESS=false
CLOUDFLARE_ACCESS_TEAM_NAME=
CLOUDFLARE_ACCESS_AUD=

# ── S3 Backup (OCI Object Storage / any S3-compatible store) ─────────────
# Backups are stored under BACKUP_S3_PREFIX/ — other objects in the bucket
# are never listed, read, or deleted. Requires boto3 (included in requirements).
#
# OCI Object Storage S3-compat endpoint format:
#   https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
#
# Create a Customer Secret Key at:
#   https://cloud.oracle.com/identity/domains/my-profile/customer-secret-keys
BACKUP_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
BACKUP_S3_BUCKET=app-backups
BACKUP_S3_PREFIX=arbiter/backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=us-chicago-1
BACKUP_MAX_GB=10.0
BACKUP_ENABLED=true
